root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.java]
# Google Java Style uses 2-space indentation
indent_size = 2
continuation_indent_size = 4

# Java 25 / Spring Boot 4 specific refinements
max_line_length = 100
ij_java_use_single_class_imports = true
ij_java_insert_inner_class_imports = true
ij_java_packages_to_use_import_on_demand = unset

# Formatting for Records and Switch Patterns (Java 25)
ij_java_record_components_wrap = split_into_lines
ij_java_new_line_before_switch_case_body = true

# Ensure Jakarta/Jackson 3 imports are grouped correctly
ij_java_import_layout = static all, |, java.*, |, javax.*, |, jakarta.*, |, *